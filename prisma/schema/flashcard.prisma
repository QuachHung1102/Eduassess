// ─── Flashcard (Ôn tập) ───────────────────────────────────────

model FlashcardSet {
  id          String     @id @default(cuid())
  title       String
  description String? // Mô tả bộ flashcard
  subjectId   String
  gradeId     String // Lớp học
  topicName   String // Chủ đề tự do (VD: "Phương trình bậc 2")
  difficulty  Difficulty // Độ khó ở cấp bộ
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  subject   Subject @relation(fields: [subjectId], references: [id])
  grade     Grade   @relation(fields: [gradeId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  cards    FlashcardCard[]
  sessions FlashcardSession[]

  @@index([subjectId])
  @@index([gradeId])
  @@index([difficulty])
  @@map("flashcard_sets")
}

// Mỗi card là 1 ảnh (front) + caption tùy chọn (back)
model FlashcardCard {
  id        String   @id @default(cuid())
  setId     String
  imageUrl  String // Cloudinary URL
  caption   String? // Chú thích / mặt sau (tùy chọn)
  order     Int
  createdAt DateTime @default(now())

  set FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@map("flashcard_cards")
}

// Phiên ôn tập của học sinh
model FlashcardSession {
  id          String    @id @default(cuid())
  setId       String
  studentId   String
  startedAt   DateTime  @default(now())
  completedAt DateTime? // NULL = chưa hoàn thành

  set     FlashcardSet @relation(fields: [setId], references: [id])
  student User         @relation(fields: [studentId], references: [id])

  @@index([setId])
  @@index([studentId])
  @@map("flashcard_sessions")
}
