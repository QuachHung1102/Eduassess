// ─── Security Answers (Câu hỏi bảo mật) ────────────────────
//
// Mỗi người dùng thiết lập 3 câu hỏi bảo mật + đáp án.
// Thiết kế normalized: 1 row / câu hỏi thay vì 6 cột trong 1 row.
// Đáp án được hash bằng bcrypt (không lưu plain text).

model SecurityAnswer {
  id           String @id @default(cuid())
  userId       String
  questionNo   Int    // 1, 2, 3 — thứ tự câu hỏi
  questionText String
  answerHash   String // bcrypt hash của đáp án (lowercase)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionNo])
  @@index([userId])
  @@map("security_answers")
}
